{
  "expo": {
    "name": "نور الدين",
    "slug": "noor-al-deen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nooraldeen.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "نحتاج موقعك لحساب أوقات الصلاة الدقيقة",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1B2A"
      },
      "package": "com.nooraldeen.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C9922E",
          "sounds": [
            "./assets/sounds/adhan.mp3",
            "./assets/sounds/ringtone.mp3"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "نحتاج موقعك لحساب أوقات الصلاة الدقيقة"
        }
      ],
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "24bbc460-cbdd-47c1-8f2c-496a76d804e3"
      }
    },
    "owner": "chaymasd"
  }
}
