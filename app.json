{
  "expo": {
    "name": "ركز على دينك",
    "slug": "ركز-على-دينك",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#060D16"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.focusondeen.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "نحتاج موقعك لحساب أوقات الصلاة الدقيقة",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#060D16"
      },
      "package": "com.focusondeen.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png",
      "name": "ركز على دينك",
      "shortName": "ركز على دينك",
      "description": "تطبيق إسلامي شخصي للنمو الروحي — أوقات الصلاة والأذكار والأدعية والقرآن",
      "themeColor": "#060D16",
      "backgroundColor": "#060D16",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "ar",
      "dir": "rtl"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C9922E",
          "sounds": [
            "./assets/sounds/adhan.mp3",
            "./assets/sounds/ringtone.mp3"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "نحتاج موقعك لحساب أوقات الصلاة الدقيقة"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "baseUrl": "/FocusAlDeen"
    },
    "extra": {
      "eas": {
        "projectId": "24bbc460-cbdd-47c1-8f2c-496a76d804e3"
      }
    },
    "owner": "chaymasd"
  }
}
